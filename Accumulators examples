5. Using `AccumulatorV2` for custom data types
pythonfrom pyspark import AccumulatorV2

class SetAccumulator(AccumulatorV2):
    def __init__(self, initial=None):
        self._set = set(initial or [])
    def isZero(self):
        return len(self._set) == 0
    def copy(self):
        return SetAccumulator(self._set)
    def reset(self):
        self._set.clear()
    def add(self, value):
        self._set.add(value)
    def merge(self, other):
        self._set.update(other._set)
    def value(self):
        return self._set

sc = SparkContext("local", "Custom Accumulator")
unique_words_acc = sc.register(SetAccumulator())

def collect_words(word):
    unique_words_acc.add(word)

rdd = sc.parallelize(["apple", "banana", "apple"])
rdd.foreach(collect_words)
print("Unique words:", unique_words_acc.value)

6. Debugging data pipeline
pythondebug_acc = sc.accumulator(0)

def debug_step(x):
    debug_acc += 1
    return x

rdd = sc.parallelize(range(100))
rdd.map(debug_step).filter(lambda x: x % 10 == 0).collect()
print("Records through debug step:", debug_acc.value)

These examples cover counters, sums, category tallies, unique value tracking with `AccumulatorV2`, and debugging metrics. Accumulators are best suited for metrics/monitoring rather than core data processing logic.
