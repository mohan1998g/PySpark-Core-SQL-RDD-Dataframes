Sure! Here’s a collection of examples showing different ways accumulators can be used in PySpark:
1. Sum of numbers (basic accumulator)
pythonfrom pyspark import SparkContext
sc = SparkContext("local", "Accumulator Example")
acc = sc.accumulator(0)

nums = [1, 2, 3, 4]
rdd = sc.parallelize(nums)

def add_num(x):
    acc += x
rdd.foreach(add_num)
print("Sum:", acc.value)

2. Counting errors
pythonerror_count = sc.accumulator(0)

def process(record):
    try:
        int(record)
    except ValueError:
        error_count += 1

rdd = sc.parallelize(["10", "abc", "20"])
rdd.foreach(process)
print("Errors:", error_count.value)

3. Tracking processed records across transformations
pythonprocessed_count = sc.accumulator(0)

def mapper(x):
    processed_count += 1
    return x * 2

rdd = sc.parallelize([1, 2, 3])
rdd.map(mapper).collect()
print("Processed records:", processed_count.value)

