from pyspark.sql.functions import array, expr

# Combines scores into an array and sums non-null elements
df = df.withColumn("total_score", 
    expr("aggregate(array(math_score, science_score, history_score), 0.0, (acc, x) -> acc + coalesce(x, 0))")
)
